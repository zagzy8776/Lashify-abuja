# ============================================================
#  LashifyAbuja - Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit your real .env to git.
# ============================================================

# --- Database (Neon PostgreSQL) ---
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# --- Admin Authentication ---
# A long random secret used to sign JWT session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-long-random-secret-here"

# The username and password you use to log in at /admin/login
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-strong-password-here"

# --- Cloudinary (Image Uploads for Gallery) ---
# Get these from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# --- Resend (Email Notifications for Bookings) ---
# Get your API key from: https://resend.com → API Keys
# Leave blank to disable email notifications.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# The email address that receives new booking notifications
ADMIN_EMAIL="your-business-email@example.com"
